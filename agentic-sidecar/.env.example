# Agentic Sidecar — Environment Variables
# Copy to .env and fill in values for local dev

# Groq API key — get from console.groq.com
GROQ_API_KEY=gsk_...

# Shared secret between backend and sidecar (leave empty to disable auth in local dev)
AGENTIC_API_KEY=

# Comma-separated specialist nodes to invoke in multi-agent pipeline
AGENTIC_MULTI_SPECIALISTS=intent,extract,policy
